# Required
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=-1001234567890
ABUSEIPDB_API_KEY=your_abuseipdb_key
ADMIN_USER_IDS=123456789,987654321

# Optional (with defaults)
AS_NUMBER=AS211407
DB_PATH=data/scanner.db
MAX_AGE_DAYS=30
TOP_OFFENDERS_COUNT=20
SCAN_CONCURRENCY=3
LOG_LEVEL=INFO
ALERT_THRESHOLD=80
NULLROUTE_MIN_SCORE=50

# Web Dashboard
WEB_ADMIN_USERNAME=user
# Generate hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt(12)).decode())"
WEB_ADMIN_PASSWORD_HASH=
# Generate key: python3 -c "import secrets; print(secrets.token_hex(32))"
WEB_SECRET_KEY=
WEB_SESSION_MAX_AGE=86400
WEB_HOST=127.0.0.1
WEB_PORT=8080
WEB_DEBUG=false
# Set true jika pakai HTTPS, false untuk HTTP
WEB_COOKIE_SECURE=false
